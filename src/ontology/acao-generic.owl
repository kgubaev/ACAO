# Class: <http://purl.obolibrary.org/obo/ACAO_0000000> (process stimulus)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/ACAO_0000000> "process stimulus"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <http://purl.obolibrary.org/obo/ACAO_0000000> "A process stimulus is a process that causally initiates, sustains, or modulates another process")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <http://purl.obolibrary.org/obo/ACAO_0000000> "combustion of fuel drives vehicle propulsion, cooling of molten metal drives solidification, implementation of a political program drives infrastructure modernization, a stress-hormone spike triggered by a chasing lion induces escape running")
SubClassOf(<http://purl.obolibrary.org/obo/ACAO_0000000> <http://purl.obolibrary.org/obo/BFO_0000015>)

# Class: <http://purl.obolibrary.org/obo/ACAO_0000001> (physical stimulus)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/ACAO_0000001> "physical stimulus"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <http://purl.obolibrary.org/obo/ACAO_0000001> "a process stimulus whose causal efficacy is grounded in physical conditions or physical interactions")
EquivalentClasses(<http://purl.obolibrary.org/obo/ACAO_0000001> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/ACAO_0000021> <http://purl.obolibrary.org/obo/ACAO_0000005>))
SubClassOf(<http://purl.obolibrary.org/obo/ACAO_0000001> <http://purl.obolibrary.org/obo/ACAO_0000000>)


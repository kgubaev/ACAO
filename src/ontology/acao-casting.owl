SubClassOf(<http://purl.obolibrary.org/obo/ACAO_0000120> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000051> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/ACAO_0000133> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/ACAO_0000022> <http://purl.obolibrary.org/obo/ACAO_0000018>))))

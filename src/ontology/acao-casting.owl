AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <http://purl.obolibrary.org/obo/ACAO_0000119> "https://www.britannica.com/technology/die-casting")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/ACAO_0000119> "die mold"@en)
SubClassOf(<http://purl.obolibrary.org/obo/ACAO_0000119> <http://purl.obolibrary.org/obo/ACAO_0000135>)

# Class: <http://purl.obolibrary.org/obo/ACAO_0000120> (die casting production process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <http://purl.obolibrary.org/obo/ACAO_0000120> "ISO 23472-1:2020(en)")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/ACAO_0000120> "die casting production process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <http://purl.obolibrary.org/obo/ACAO_0000120> "Casting process in which molten metal is injected into a die and held under pressure until complete solidification.")

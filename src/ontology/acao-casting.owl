AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/ACAO_0000123> "investment casting production process"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <http://purl.obolibrary.org/obo/ACAO_0000123> "Casting process where waxes are embedded into investment and destroyed during dewaxing and burnout to produce near net shaped metal components.")
SubClassOf(<http://purl.obolibrary.org/obo/ACAO_0000123> <http://purl.obolibrary.org/obo/ACAO_0000106>)

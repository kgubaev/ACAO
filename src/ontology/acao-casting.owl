# Class: <http://purl.obolibrary.org/obo/ACAO_0000114> (packed granular mold)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <http://purl.obolibrary.org/obo/ACAO_0000114> "https://www.britannica.com/technology/founding-technology")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/ACAO_0000114> "packed granular mold"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <http://purl.obolibrary.org/obo/ACAO_0000114> "The mold made of materials like sand or clay, that are packed over the face of the pattern (usually made of wood, metal, or resin) to form the cavity into which the molten metal is to be poured. Molds are usually constructed in two halves, and the two halves are joined together once the pattern has been removed from them.")
SubClassOf(<http://purl.obolibrary.org/obo/ACAO_0000114> <http://purl.obolibrary.org/obo/ACAO_0000135>)

# Class: <http://purl.obolibrary.org/obo/ACAO_0000115> (casting mold cavity)

AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/ACAO_0000115> "casting mold cavity"@en)
EquivalentClasses(<http://purl.obolibrary.org/obo/ACAO_0000115> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/ACAO_0000103>))
SubClassOf(<http://purl.obolibrary.org/obo/ACAO_0000115> <https://w3id.org/pmd/co/PMD_0020204>)

# Class: <http://purl.obolibrary.org/obo/ACAO_0000116> (split die mold)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/ACAO_0000116> "A clamped die mold composed of separable parts that form the cavity during die casting and are opened after solidification for ejection of the part")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <http://purl.obolibrary.org/obo/ACAO_0000116> "https://www.sciencedirect.com/topics/engineering/die-casting")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/ACAO_0000116> "split die mold"@en)
SubClassOf(<http://purl.obolibrary.org/obo/ACAO_0000116> <http://purl.obolibrary.org/obo/ACAO_0000119>)

# Class: <http://purl.obolibrary.org/obo/ACAO_0000117> (continous casting mold)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/ACAO_0000117> "A short water-cooled mold used in continuous casting, through which the forming shell/strand is continuously withdrawn.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <http://purl.obolibrary.org/obo/ACAO_0000117> "https://www.britannica.com/technology/steel/Continuous-casting")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/ACAO_0000117> "continous casting mold"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#altLabel> <http://purl.obolibrary.org/obo/ACAO_0000117> "open-ended mold")
SubClassOf(<http://purl.obolibrary.org/obo/ACAO_0000117> <http://purl.obolibrary.org/obo/ACAO_0000135>)

# Class: <http://purl.obolibrary.org/obo/ACAO_0000118> (rotating mold)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000119> <http://purl.obolibrary.org/obo/ACAO_0000118> "https://www.britannica.com/technology/iron-processing/The-metal")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/ACAO_0000118> "rotating mold"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <http://purl.obolibrary.org/obo/ACAO_0000118> "A mold rotated during centrifugal casting so that the melt is shaped while the mold spins.")
SubClassOf(<http://purl.obolibrary.org/obo/ACAO_0000118> <http://purl.obolibrary.org/obo/ACAO_0000135>)


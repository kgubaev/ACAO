    <!-- http://purl.obolibrary.org/obo/ACAO_0000028 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000028">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020246"/>
        <rdfs:label xml:lang="en">cavity filling process</rdfs:label>
        <skos:definition>The process of continuous transport of gas or liquid into the cavity of the solid object, or into otherwise confined place in 3D space (e.g., filling of plasma into the confined magnetic field).</skos:definition>
    </owl:Class>
    



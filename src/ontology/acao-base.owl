    <!-- http://purl.obolibrary.org/obo/ACAO_0000000 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">process stimulus</rdfs:label>
        <skos:definition>A process stimulus is a process that causally initiates, sustains, or modulates another process</skos:definition>
        <skos:example>combustion of fuel drives vehicle propulsion, cooling of molten metal drives solidification, implementation of a political program drives infrastructure modernization, a stress-hormone spike triggered by a chasing lion induces escape running</skos:example>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000001">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000021"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000005"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000021"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000005"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">physical stimulus</rdfs:label>
        <skos:definition>a process stimulus whose causal efficacy is grounded in physical conditions or physical interactions</skos:definition>
    </owl:Class>
    



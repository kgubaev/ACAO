        <obo:IAO_0000119>ISO 23472-1:2020(en)</obo:IAO_0000119>
        <rdfs:label xml:lang="en">die casting production process</rdfs:label>
        <skos:definition>Casting process in which molten metal is injected into a die and held under pressure until complete solidification.</skos:definition>
    </owl:Class>
    



        <rdfs:range rdf:resource="https://w3id.org/pmd/co/PMD_0000001"/>
        <rdfs:label xml:lang="en">has constitutive material</rdfs:label>
        <skos:definition>Relates an artifact or other material entity to a portion of matter that is part of it and contributes to its characteristic material constitution, without by itself specifying exact composition or quantitative proportion.</skos:definition>
    </owl:ObjectProperty>
    



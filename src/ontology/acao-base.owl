    <!-- http://purl.obolibrary.org/obo/ACAO_0000105 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000105">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000100"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ACAO_0000133"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000057"/>
                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000117"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000119>ISO 197-4:1983(en)</obo:IAO_0000119>
        <rdfs:label xml:lang="en">continuous casting production process</rdfs:label>
        <skos:definition>Casting fromed by supplying metal continuously to a mould, and withdrawing it continuously from some other part of the mould as it solidifies, the length being independent of the mould dimensions.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000106 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000106">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000100"/>
        <rdfs:label xml:lang="en">discrete casting production process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000107 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000107">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0000000"/>
        <rdfs:label xml:lang="en">mold material portion</rdfs:label>
        <skos:definition>A portion of matter that is part of a casting mold and contributes to the mold’s characteristic material constitution, rather than occurring in or on the mold merely accidentally or incidentally.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000108 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000108">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000107"/>
        <rdfs:label xml:lang="en">sand based mold material portion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000109 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000109">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000135"/>
        <obo:IAO_0000119>https://www.britannica.com/technology/shell-mold-casting</obo:IAO_0000119>
        <rdfs:label xml:lang="en">shell mold</rdfs:label>
        <skos:definition>A mold formed by the shell-molding process, in which resin-coated sand hardens on a heated metal pattern to form thin, strong mold halves that are then assembled.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000110 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000110">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000107"/>
        <rdfs:label xml:lang="en">ceramic based mold material portion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000111 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000111">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000107"/>
        <rdfs:label xml:lang="en">plaster based mold material portion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000112 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000112">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000107"/>
        <rdfs:label xml:lang="en">metal based mold material portion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000113 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000113">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000107"/>
        <rdfs:label xml:lang="en">graphite based mold material portion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000114 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000114">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000135"/>
        <obo:IAO_0000119>https://www.britannica.com/technology/founding-technology</obo:IAO_0000119>
        <rdfs:label xml:lang="en">packed granular mold</rdfs:label>
        <skos:definition>The mold made of materials like sand or clay, that are packed over the face of the pattern (usually made of wood, metal, or resin) to form the cavity into which the molten metal is to be poured. Molds are usually constructed in two halves, and the two halves are joined together once the pattern has been removed from them.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000115 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000115">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000103"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020204"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000103"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">casting mold cavity</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000116 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000116">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000119"/>
        <obo:IAO_0000115>A clamped die mold composed of separable parts that form the cavity during die casting and are opened after solidification for ejection of the part</obo:IAO_0000115>
        <obo:IAO_0000119>https://www.sciencedirect.com/topics/engineering/die-casting</obo:IAO_0000119>
        <rdfs:label xml:lang="en">split die mold</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000117 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000117">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000135"/>
        <obo:IAO_0000115>A short water-cooled mold used in continuous casting, through which the forming shell/strand is continuously withdrawn.</obo:IAO_0000115>
        <obo:IAO_0000119>https://www.britannica.com/technology/steel/Continuous-casting</obo:IAO_0000119>
        <rdfs:label xml:lang="en">continous casting mold</rdfs:label>
        <skos:altLabel>open-ended mold</skos:altLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000118 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000118">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000135"/>
        <obo:IAO_0000119>https://www.britannica.com/technology/iron-processing/The-metal</obo:IAO_0000119>
        <rdfs:label xml:lang="en">rotating mold</rdfs:label>
        <skos:definition>A mold rotated during centrifugal casting so that the melt is shaped while the mold spins.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ACAO_0000119 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ACAO_0000119">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ACAO_0000135"/>
        <obo:IAO_0000115>A casting mold used in die casting, into which the liquid metal is injected.</obo:IAO_0000115>
        <obo:IAO_0000119>https://www.britannica.com/technology/die-casting</obo:IAO_0000119>
        <rdfs:label xml:lang="en">die mold</rdfs:label>
    </owl:Class>
    



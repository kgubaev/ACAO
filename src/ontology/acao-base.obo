name: pressure gradient condition
is_a: ACAO:0000016 ! thermodynamic gradient condition

[Term]
id: ACAO:0000019
name: chemical potential gradient condition
is_a: ACAO:0000016 ! thermodynamic gradient condition

[Term]
id: ACAO:0000020
name: concentration gradient condition
is_a: ACAO:0000016 ! thermodynamic gradient condition


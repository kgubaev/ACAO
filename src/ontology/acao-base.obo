[Term]
id: ACAO:0000137
name: reusable casting mold
is_a: ACAO:0000138 ! persistence specified casting mold
relationship: RO:0000053 ACAO:0000024 ! multiple use disposition

[Term]
id: ACAO:0000138
name: persistence specified casting mold
is_a: ACAO:0000103 ! casting mold

[Term]
id: ACAO:0000139
name: material specified casting mold
is_a: ACAO:0000103 ! casting mold

[Term]
id: ACAO:0000140
name: sand based casting mold
is_a: ACAO:0000139 ! material specified casting mold

[Term]
id: ACAO:0000141
name: ceramic based casting mold
is_a: ACAO:0000139 ! material specified casting mold
relationship: ACAO:0000029 ACAO:0000110 ! has constitutive material ceramic based mold material portion

[Term]
id: ACAO:0000142
name: plaster based casting mold
is_a: ACAO:0000139 ! material specified casting mold

[Term]
id: ACAO:0000143
name: metal based casting mold
is_a: ACAO:0000139 ! material specified casting mold

[Term]
id: ACAO:0000144
name: graphite based casting mold
is_a: ACAO:0000139 ! material specified casting mold

[Typedef]
id: ACAO:0000003
name: has driving condition
holds_over_chain: ACAO:0000022 ACAO:0000021

[Typedef]
id: ACAO:0000021
name: has basis in
domain: ACAO:0000000 ! process stimulus


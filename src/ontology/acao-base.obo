[Term]
id: ACAO:0000000
name: process stimulus
is_a: BFO:0000015
property_value: skos:definition "A process stimulus is a process that causally initiates, sustains, or modulates another process" xsd:string
property_value: skos:example "combustion of fuel drives vehicle propulsion, cooling of molten metal drives solidification, implementation of a political program drives infrastructure modernization, a stress-hormone spike triggered by a chasing lion induces escape running" xsd:string

[Term]
id: ACAO:0000001
name: physical stimulus
is_a: ACAO:0000000 ! process stimulus
relationship: ACAO:0000021 ACAO:0000005 ! has basis in physical dynamic condition
property_value: skos:definition "a process stimulus whose causal efficacy is grounded in physical conditions or physical interactions" xsd:string

[Term]
id: ACAO:0000002
name: stimulated process
is_a: BFO:0000015
relationship: ACAO:0000022 ACAO:0000000 ! stimulated by process stimulus

[Term]
id: ACAO:0000004
name: usage disposition
is_a: BFO:0000016


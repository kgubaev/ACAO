is_a: co:PMD_0025018 ! geometric relational quality
property_value: co:PMD_0001032 https://github.com/materialdigital/core-ontology/issues/278
property_value: skos:definition "A property that represents the measure of rotation or inclination between two intersecting lines or planes, independent of the size of the object." xsd:string

[Term]

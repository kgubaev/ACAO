property_value: co:PMD_0001032 https://github.com/materialdigital/core-ontology/issues/278
property_value: skos:definition "A quantitative indication of the doubt about a measurement result, expressing the range within which the true value is expected to lie." xsd:string

[Term]
id: co:PMD_0001039
name: calibration process
is_a: COB:0000035 ! completely executed planned process
property_value: co:PMD_0001032 https://github.com/materialdigital/core-ontology/issues/278
property_value: skos:definition "A process of comparing measurement values delivered by an instrument or system with known reference standards to ensure accuracy and traceability." xsd:string

[Term]
id: co:PMD_0001040
name: expriment designing process
is_a: COB:0000035 ! completely executed planned process
property_value: co:PMD_0001032 https://github.com/materialdigital/core-ontology/issues/278
property_value: skos:definition "A planned process of planning and structuring experimental methods, conditions, and variables to reliably test hypotheses or obtain data." xsd:string

[Term]
id: co:PMD_0001042

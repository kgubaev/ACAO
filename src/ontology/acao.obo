is_a: COB:0000082 ! planned process
property_value: co:PMD_0001032 https://github.com/materialdigital/core-ontology/issues/278
property_value: IAO:0000119 "https://www.britannica.com/science/sample-preparation" xsd:string
property_value: skos:definition "A planned processes in which a representative piece of material is extracted from a larger amount and readied for analysis. " xsd:string

[Term]
id: co:PMD_0001044
name: date value specification
is_a: OBI:0001933 ! value specification
property_value: co:PMD_0001032 https://github.com/materialdigital/core-ontology/issues/278
property_value: skos:definition "A datum that represents a date or time interval associated with another specification." xsd:string

[Term]
id: co:PMD_0001046
name: depth
is_a: co:PMD_0020132 ! size
property_value: co:PMD_0001032 https://github.com/materialdigital/core-ontology/issues/278
property_value: skos:definition "The distance from a reference surface or point to a specific point or feature along a perpendicular or defined direction." xsd:string

[Term]
id: co:PMD_0001047
name: diagonal
is_a: co:PMD_0020132 ! size
property_value: co:PMD_0001032 https://github.com/materialdigital/core-ontology/issues/278
property_value: skos:definition "A straight line connecting two non-adjacent corners or vertices of a polygon." xsd:string

[Term]
id: co:PMD_0001998
name: cutting device
property_value: skos:definition "A device designed to cut, slice, divide, or sever objects." xsd:string

[Term]
id: co:PMD_0001999
name: hand held device
is_a: co:PMD_0000602 ! Gerät
intersection_of: co:PMD_0000602 ! Gerät
intersection_of: RO:0000091 co:PMD_0000769 ! has disposition hand holdable disposition
relationship: RO:0000091 co:PMD_0000769 ! has disposition hand holdable disposition
property_value: skos:definition "A device that has the disposition to be grasped and operated by a human hand and is designed for manual use." xsd:string


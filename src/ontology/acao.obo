property_value: skos:comment "produced through biological synthesis processes like Biological growth, morphogenesis, secretion etc." xsd:string
property_value: skos:definition "material produced by a living organism" xsd:string
property_value: skos:example "Biological Comosite such as Wood, Bone, Silk, Wool;  Biopolymers such as cellulose, colagene;  Biogenic minerals such as hydroxyapatite" xsd:string

[Term]
id: co:PMD_0090013
name: biological composite
is_a: co:PMD_0000577 ! composite
intersection_of: co:PMD_0000577 ! composite
intersection_of: RO:0002353 GO:0008150 ! output of biological_process
relationship: RO:0002353 GO:0008150 ! output of biological_process
property_value: co:PMD_0001032 "https://github.com/materialdigital/core-ontology/issues/354" xsd:string
property_value: skos:definition "composite consisting of two or more distinct material phases organized in a multi-scale structure that act synergistically to fulfill specific properties or functions" xsd:string
property_value: skos:example " such as Wood, Bone, Silk, Wool;" xsd:string

[Term]
id: co:PMD_0090014
name: biopolymer
is_a: co:PMD_0000888 ! polymer
is_a: co:PMD_0090012 ! biological material
intersection_of: co:PMD_0000888 ! polymer
intersection_of: co:PMD_0090012 ! biological material
property_value: co:PMD_0001032 "https://github.com/materialdigital/core-ontology/issues/354" xsd:string
property_value: skos:altLabel "biomacromoleules" xsd:string
property_value: skos:definition "polymer produced by the metabolic processes of a living organism" xsd:string
property_value: skos:example "such as Polysaccharides like cellulose or Chitin; Proteins like colagene or Fibroin" xsd:string

[Term]
id: co:PMD_0090015
name: biogenic mineral
is_a: co:PMD_0000127 ! mineral
is_a: co:PMD_0090012 ! biological material
intersection_of: co:PMD_0000127 ! mineral
intersection_of: RO:0002353 GO:0008150 ! output of biological_process
property_value: co:PMD_0001032 "https://github.com/materialdigital/core-ontology/issues/354" xsd:string
property_value: skos:definition "mineral that is inorganic crystalline or amorphous solid synthesized by a living organism" xsd:string
property_value: skos:example "such as Calcium Carbonates (in shells), Calcium Phosphates (Hydroxyapatite in bone/teeth), or Silica (in diatoms)" xsd:string

[Term]
id: co:PMD_0090016
name: bio-based material
is_a: co:PMD_0000000 ! Material
property_value: co:PMD_0001032 "https://github.com/materialdigital/core-ontology/issues/354" xsd:string
property_value: skos:comment "produced through industrial syntesis processes like Chemical extraction, fermentation, or polymerization" xsd:string
property_value: skos:definition "material intentionally processed from materials derived from living (or once-living) organisms" xsd:string
property_value: skos:example "Engineered Biopolymers such as Polylactic Acid (PLA);  Reconstituted Biopolymers such as Regenerated Cellulose (Rayon/Viscose); Biocomposites such as Wood-Plastic Composites (WPC);  Biochemicals (e.g. Bio-based Adhesives)" xsd:string

[Term]
id: co:PMD_0090017
name: engineered biopolymer
is_a: co:PMD_0090016 ! bio-based material
property_value: co:PMD_0001032 "https://github.com/materialdigital/core-ontology/issues/354" xsd:string
property_value: skos:definition "bio-based material and polymer synthesized through the intentional industrial transformation, synthesis, or reconstitution processes using materials derived from living (or once-living) organisms" xsd:string
property_value: skos:example "synthetic Bio-polymer such as Polylactic Acid (PLA): or Regenrated Biopolymrs like Rayon / Viscose reconstituted from pulp cellulose; or microbial Biopolymers like Polyhydroxyalkanoates (PHA) synthesised by bacteria" xsd:string

[Term]
id: co:PMD_0090018
name: bio-based composite
is_a: co:PMD_0000577 ! composite
intersection_of: co:PMD_0000577 ! composite
intersection_of: BFO:0000051 co:PMD_0090016 ! has part bio-based material
relationship: BFO:0000051 co:PMD_0090016 ! has part bio-based material
property_value: co:PMD_0001032 "https://github.com/materialdigital/core-ontology/issues/354" xsd:string
property_value: skos:altLabel "biocomposite; bio-composite" xsd:string
property_value: skos:definition "composite consisting of at least one constituent derived from biological or bio-based sources" xsd:string
property_value: skos:example "such as Wood-Plastic Composite (WPC), Hemp-fiber reinforced Polypropylene" xsd:string

[Term]
id: co:PMD_0090019
name: bio-based chemical
is_a: co:PMD_0090016 ! bio-based material
property_value: co:PMD_0001032 "https://github.com/materialdigital/core-ontology/issues/354" xsd:string
property_value: skos:altLabel "biochemicals" xsd:string
property_value: skos:definition "bio-based material used in chemical reactions as a reactant" xsd:string
property_value: skos:example "such as bio-based adhesives (e.g. Lignin-based); Bio-epoxy resin." xsd:string

[Term]
id: co:PMD_0090050
name: thermosetting polyurethane
is_a: co:PMD_0050022 ! thermosetting polymer
property_value: co:PMD_0050117 "PUR" xsd:string
property_value: skos:comment "offers high versatility in mechanical properties" xsd:string
property_value: skos:definition "thermosetting polymer with carbamate crosslinks" xsd:string

[Term]
id: co:PMD_0090051
name: unsaturated polyester resins
is_a: co:PMD_0050022 ! thermosetting polymer
property_value: skos:comment "they are used for fiber-reinforced composites" xsd:string
property_value: skos:definition "thermosetting polymer system of unsaturated polyester prepolymers in reactive vinyl monomers; it cures by radical crosslinking into rigid networks" xsd:string

[Term]
id: co:PMD_0090052
name: silicone rubber
is_a: co:PMD_0050032 ! synthetic rubber
property_value: skos:comment "it is available in multiple formulations and often filled." xsd:string
property_value: skos:comment "wide service temperature range" xsd:string
property_value: skos:definition "synthetic rubber that belongs to crosslinked polysiloxane elastomer family, with organic side groups" xsd:string
property_value: skos:example "widely used for its broad service temperature range in medical devices, gaskets, and culinary tools" xsd:string

[Term]
id: co:PMD_0090053
name: polychloropren
is_a: co:PMD_0050032 ! synthetic rubber
property_value: skos:altLabel " Neoprene" xsd:string
property_value: skos:comment "it offers good weathering and ozone resistance." xsd:string
property_value: skos:comment "weathering resistance; ozone resistance" xsd:string
property_value: skos:definition "synthetic rubber that belongs to the family of synthetic elastomeric rubbers; synthesised typically through emulsion polymerization of chloroprene" xsd:string
property_value: skos:example " it is widely used in gaskets and wetsuits. " xsd:string

[Term]
id: co:PMD_0200000
name: Pressformen
is_a: co:PMD_0000907 ! Urformen Aus Dem Plastischen Zustand
property_value: dce:source "Official definition can be found in: DIN 8580, group 1.2.1 “Pressformen”." xsd:string
property_value: dce:source "Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.1 „Pressformen“." xsd:string
property_value: skos:altLabel "compression moulding" xsd:string
property_value: skos:definition "A primary shaping from the plastic state process in which a pre-measured, usually preheated molding compound is placed in an open, heated mold cavity and shaped by closing the mold and applying pressure until the material cures or solidifies to the final part geometry." xsd:string
property_value: skos:definition "Ein Urformverfahren, bei dem eine dosierte, meist vorgewärmte Formmasse in eine offene, beheizte Formkavität eingelegt und durch Schließen des Werkzeugs unter Druck zur endgültigen Bauteilgeometrie ausgehärtet bzw. erstarrt wird." xsd:string

[Term]
id: co:PMD_0200001
name: Biologische Abbaubarkeit
is_a: BFO:0000016 ! disposition
property_value: co:PMD_0001032 "https://github.com/materialdigital/core-ontology/issues/126" xsd:string
property_value: IAO:0000119 "orginal: \"[biodegradability] [...] is understood as the microbial conversion of all its organic constituents to carbon dioxide (or carbon dioxide and methane in conditions where oxygen is not present), new microbial biomass and mineral salts, within a timescale short enough not to lead to lasting harm or accumulation in the open environment.\"\n\nEuropean Commission: Directorate-General for Research and Innovation, Biodegradability of plastics in the open environment, Publications Office of the European Union, 2021, https://data.europa.eu/doi/10.2777/690248" xsd:string
property_value: skos:definition "\"[Biologische Abbaubarkeit] [...] beschreibt die mikrobielle Umwandlung all seiner organischen Bestandteile in Kohlendioxid oder – unter sauerstofffreien Bedingungen – in Kohlendioxid und Methan, neue mikrobielle Biomasse und Mineralsalze verstanden, und zwar innerhalb eines Zeitraums, der so kurz ist, dass es nicht zu dauerhaften Schäden oder Anreicherungen in der offenen Umwelt kommt.\"" xsd:string
property_value: skos:definition "biodegradability is a disposition of a material which specifies its capability to be fully microbially converted into inorganic end products (CO₂, CH₄, mineral salts, biomass) within an environmentally non-harmful timescale." xsd:string

[Term]
id: co:PMD_0200002
name: Spritzgießen
is_a: co:PMD_0000907 ! Urformen Aus Dem Plastischen Zustand
property_value: dce:source "Official definition can be found in: DIN 8580, group 1.2.2 “Spritzgießen”." xsd:string
property_value: dce:source "Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.2 „Spritzgießen“." xsd:string
property_value: skos:altLabel "injection moulding; plastic injection molding" xsd:string
property_value: skos:definition "A primary shaping from the plastic state process in which plastic granules are plasticised in an injection unit and the melt is injected under high pressure into a closed mold cavity, where it cools and solidifies to the final part shape." xsd:string
property_value: skos:definition "Urformverfahren, bei dem Kunststoffgranulat in einem Plastifizieraggregat aufgeschmolzen und die Schmelze mit hohem Druck in einen geschlossenen Formhohlraum eingespritzt wird, wo sie verdichtet, abkühlt und zum Formteil erstarrt." xsd:string
property_value: skos:example "Injection molding of polypropylene housings." xsd:string

[Term]
id: co:PMD_0200003
name: Spritzpressen
is_a: co:PMD_0000907 ! Urformen Aus Dem Plastischen Zustand
property_value: dce:source "Official definition can be found in: DIN 8580, group 1.2.3 “Spritzpressen”." xsd:string
property_value: dce:source "Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.3 „Spritzpressen“." xsd:string
property_value: skos:altLabel "injection–compression moulding; transfer molding (Spritzpressen)" xsd:string
property_value: skos:definition "A hybrid primary shaping from the plastic state process that combines injection and compression: a pre-plasticised charge or melt is injected into a closed or partially open mold and then compressed by further mold closure or a plunger so that the material completely fills the cavity and cures or solidifies under heat and pressure." xsd:string
property_value: skos:definition "Urformverfahren, bei dem eine vorplastifizierte Formmasse aus einer beheizten Vorkammer bzw. einem Plastifizieraggregat in ein (teil-)geschlossenes Werkzeug eingespritzt und anschließend durch Schließen des Werkzeugs bzw. Nachdrücken verpresst wird, bis der Werkstoff unter Wärme und Druck aushärtet." xsd:string
property_value: skos:example "Injection-compression molding of epoxy-encapsulated electronic components." xsd:string

[Term]
id: co:PMD_0200004
name: extrusion
is_a: co:PMD_0000907 ! Urformen Aus Dem Plastischen Zustand
property_value: dce:source "Official definition can be found in: DIN 8580, group 1.2.4 " xsd:string
property_value: dce:source "Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.4 " xsd:string
property_value: skos:definition "A primary shaping from the plastic state process in which a plastically deformable material, typically a polymer melt, is continuously forced by pressure through a shaping die to produce an endless strand with constant cross-section, which solidifies by cooling or curing." xsd:string
property_value: skos:definition "Ein Urformverfahren, bei dem ein plastifizierter Werkstoff, meist eine Polymerschmelze, kontinuierlich unter Druck durch eine formgebende Düse gepresst wird und dabei einen Strang mit konstantem Querschnitt bildet, der durch Abkühlen oder Aushärten verfestigt wird." xsd:string
property_value: skos:example "Extrusion of PVC window profiles; extrusion of plastic films or pipes from polyethylene melt." xsd:string

[Term]
id: co:PMD_0200005
name: Ziehformen
is_a: co:PMD_0000907 ! Urformen Aus Dem Plastischen Zustand
property_value: dce:source "Official definition can be found in: DIN 8580, group 1.2.5 " xsd:string
property_value: dce:source "Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.5 " xsd:string
property_value: skos:definition "A primary shaping from the plastic state process in which a plastically deformable mass (for example fibre-reinforced resin or glass/plastic strands) is pulled through one or more shaping tools or dies so that the cross-section and surface are formed by tensile forces, while the material solidifies or cures to produce continuous profiles. It is conceptually related to pultrusion / profile drawing." xsd:string
property_value: skos:definition "Ein Urformverfahren, bei dem eine plastisch verformbare Masse (z. B. faserverstärkte Harzsysteme oder glasige/kunststoffhaltige Stränge) durch Zugkräfte durch formgebende Düsen oder Werkzeuge gezogen wird, sodass Querschnitt und Oberfläche ausgebildet und der Werkstoff dabei verfestigt bzw. ausgehärtet wird. Das Verfahren ist verwandt mit dem Strangzieh- bzw. Pultrusionsverfahren." xsd:string
property_value: skos:example "Pultrusion of glass-fibre-reinforced polymer profiles; drawing of continuous fibre-reinforced rods through a heated die." xsd:string

[Term]
id: co:PMD_0200006
name: Kalandrieren
is_a: co:PMD_0000907 ! Urformen Aus Dem Plastischen Zustand
property_value: dce:source "Official definition can be found in: DIN 8580, group 1.2.6 " xsd:string
property_value: dce:source "Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.6 " xsd:string
property_value: skos:definition "A primary shaping from the plastic state process in which a viscous polymer melt or plastic mass is passed through the narrow gaps between several counter-rotating, polished rolls so that it is compressed and rolled out into sheet or film of defined thickness and surface quality, then cooled to solidify." xsd:string
property_value: skos:definition "Ein Urformverfahren, bei dem eine zähflüssige Polymerschmelze oder plastische Masse durch enge Spalte zwischen mehreren gegenläufig rotierenden, polierten Walzen geführt wird, wodurch sie verdichtet und zu Platten oder Folien definierter Dicke und Oberflächenqualität ausgewalzt und anschließend verfestigt wird." xsd:string
property_value: skos:example "Calendering of plasticised PVC into rigid or flexible sheets and films; calendering of ABS sheet for thermoforming." xsd:string

[Term]
id: co:PMD_0200007
name: Blasformen
is_a: co:PMD_0000907 ! Urformen Aus Dem Plastischen Zustand
property_value: dce:source "Official definition can be found in: DIN 8580, group 1.2.7 " xsd:string
property_value: dce:source "Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.7 " xsd:string
property_value: skos:definition "A primary shaping from the plastic state process in which a tube or preform of molten or plasticised material is enclosed in a mold and expanded by internal gas pressure so that it conforms to the mold cavity, producing hollow bodies which then solidify." xsd:string
property_value: skos:definition "Ein Urformverfahren, bei dem ein Schlauch oder ein Vorformling aus geschmolzenem bzw. plastifizierten Werkstoff in ein Werkzeug eingelegt und durch inneren Gasdruck an die Formwand aufgeblasen wird, sodass ein Hohlkörper entsteht, der anschließend verfestigt wird." xsd:string
property_value: skos:example "Extrusion blow molding of HDPE bottles; stretch-blow molding of PET beverage containers; blow molding of fuel tanks for automotive applications." xsd:string

[Term]
id: co:PMD_0200008
name: Modellieren
is_a: co:PMD_0000907 ! Urformen Aus Dem Plastischen Zustand
property_value: dce:source "Official definition can be found in: DIN 8580, group 1.2.8 " xsd:string
property_value: dce:source "Offizielle Definition findet man in: DIN 8580, Gruppe 1.2.8 " xsd:string
property_value: skos:definition "A primary shaping from the plastic state process in which a manually workable plastic mass (such as clay, wax, plastiline or gypsum paste) is shaped directly by hand and simple tools into a final or intermediate geometry and subsequently hardened, dried or fired to obtain a solid body." xsd:string
property_value: skos:definition "Ein Urformverfahren, bei dem eine mit Hand und einfachen Werkzeugen formbare plastische Masse (z. B. Ton, Wachs, Plastilin oder Gipspaste) direkt zur gewünschten Geometrie modelliert und anschließend durch Trocknen, Brennen oder Aushärten zu einem festen Körper verfestigt wird." xsd:string
property_value: skos:example "Hand modelling of clay prior to firing (e.g. pottery, sculptures); modelling of wax or plasticine for casting patterns." xsd:string

[Term]
id: http://www.ontology-of-units-of-measure.org/resource/om-2/MassFraction
name: mass fraction

[Term]
id: http://www.ontology-of-units-of-measure.org/resource/om-2/VolumeFraction
name: volume fraction

[Typedef]
id: ACAO:0000003
name: has driving condition
holds_over_chain: ACAO:0000022 ACAO:0000021

[Typedef]
id: ACAO:0000021
name: has basis in
domain: ACAO:0000000 ! process stimulus

[Typedef]
id: ACAO:0000022
name: stimulated by
domain: BFO:0000015 ! process
range: ACAO:0000000 ! process stimulus

[Typedef]
id: ACAO:0000029
name: has constitutive material
property_value: skos:definition "Relates an artifact or other material entity to a portion of matter that is part of it and contributes to its characteristic material constitution, without by itself specifying exact composition or quantitative proportion." xsd:string
domain: BFO:0000040 ! material entity
range: co:PMD_0000001 ! portion of matter
is_a: BFO:0000051 ! has part

[Typedef]
id: BFO:0000050
name: part of
def: "a core relation that holds between a part and its whole" []
property_value: IAO:0000111 "is part of" xsd:string
property_value: IAO:0000112 "my brain is part of my body (continuant parthood, two material entities)" xsd:string
property_value: IAO:0000112 "my stomach cavity is part of my stomach (continuant parthood, immaterial entity is part of material entity)" xsd:string
property_value: IAO:0000112 "this day is part of this year (occurrent parthood)" xsd:string
property_value: IAO:0000116 "Everything is part of itself. Any part of any part of a thing is itself part of that thing. Two distinct things cannot be part of each other." xsd:string
property_value: IAO:0000116 "Occurrents are not subject to change and so parthood between occurrents holds for all the times that the part exists. Many continuants are subject to change, so parthood between continuants will only hold at certain times, but this is difficult to specify in OWL. See http://purl.obolibrary.org/obo/ro/docs/temporal-semantics/" xsd:string
property_value: IAO:0000116 "Parthood requires the part and the whole to have compatible classes: only an occurrent can be part of an occurrent; only a process can be part of a process; only a continuant can be part of a continuant; only an independent continuant can be part of an independent continuant; only an immaterial entity can be part of an immaterial entity; only a specifically dependent continuant can be part of a specifically dependent continuant; only a generically dependent continuant can be part of a generically dependent continuant. (This list is not exhaustive.)\n\nA continuant cannot be part of an occurrent: use 'participates in'. An occurrent cannot be part of a continuant: use 'has participant'. A material entity cannot be part of an immaterial entity: use 'has location'. A specifically dependent continuant cannot be part of an independent continuant: use 'inheres in'. An independent continuant cannot be part of a specifically dependent continuant: use 'bearer of'." xsd:string
property_value: IAO:0000118 "part_of" xsd:string
property_value: RO:0001900 RO:0001901
property_value: seeAlso "http://www.obofoundry.org/ro/#OBO_REL:part_of" xsd:string
is_transitive: true
inverse_of: BFO:0000051 ! has part

[Typedef]
id: BFO:0000051
name: has part
def: "a core relation that holds between a whole and its part" []
property_value: IAO:0000111 "has part" xsd:string
property_value: IAO:0000112 "my body has part my brain (continuant parthood, two material entities)" xsd:string
property_value: IAO:0000112 "my stomach has part my stomach cavity (continuant parthood, material entity has part immaterial entity)" xsd:string
property_value: IAO:0000112 "this year has part this day (occurrent parthood)" xsd:string
property_value: IAO:0000116 "Everything has itself as a part. Any part of any part of a thing is itself part of that thing. Two distinct things cannot have each other as a part." xsd:string
property_value: IAO:0000116 "Occurrents are not subject to change and so parthood between occurrents holds for all the times that the part exists. Many continuants are subject to change, so parthood between continuants will only hold at certain times, but this is difficult to specify in OWL. See http://purl.obolibrary.org/obo/ro/docs/temporal-semantics/" xsd:string
property_value: IAO:0000116 "Parthood requires the part and the whole to have compatible classes: only an occurrent have an occurrent as part; only a process can have a process as part; only a continuant can have a continuant as part; only an independent continuant can have an independent continuant as part; only a specifically dependent continuant can have a specifically dependent continuant as part; only a generically dependent continuant can have a generically dependent continuant as part. (This list is not exhaustive.)\n\nA continuant cannot have an occurrent as part: use 'participates in'. An occurrent cannot have a continuant as part: use 'has participant'. An immaterial entity cannot have a material entity as part: use 'location of'. An independent continuant cannot have a specifically dependent continuant as part: use 'bearer of'. A specifically dependent continuant cannot have an independent continuant as part: use 'inheres in'." xsd:string
property_value: IAO:0000118 "has_part" xsd:string
property_value: RO:0001900 RO:0001901
is_transitive: true
is_a: BFO:0000051 ! has part

[Typedef]
id: BFO:0000054
name: has realization
property_value: skos:definition "b has realization c =Def c realizes b" xsd:string
property_value: skos:example "As for realizes" xsd:string
domain: BFO:0000017 ! realizable entity
range: BFO:0000015 ! process
inverse_of: BFO:0000055 ! realizes

[Typedef]
id: BFO:0000055
name: realizes
def: "Paraphrase of elucidation: a relation between a process and a realizable entity, where there is some material entity that is bearer of the realizable entity and participates in the process, and the realizable entity comes to be realized in the course of the process" []
property_value: skos:definition "(Elucidation) realizes is a relation between a process b and realizable entity c such that c inheres in some d & for all t, if b has participant d then c exists & the type instantiated by b is correlated with the type instantiated by c" xsd:string
property_value: skos:example "A balding process realizes a disposition to go bald; a studying process realizes a student role; a process of pumping blood realizes the pumping function of a heart" xsd:string
domain: BFO:0000015 ! process
range: BFO:0000017 ! realizable entity

[Typedef]
id: BFO:0000062
name: preceded by
def: "x is preceded by y if and only if the time point at which y ends is before or equivalent to the time point at which x starts. Formally: x preceded by y iff ω(y) <= α(x), where α is a function that maps a process to a start point, and ω is a function that maps a process to an end point." []
property_value: skos:definition "b preceded by c =Def b precedes c" xsd:string
property_value: skos:example "The temporal region occupied by the second half of the match is preceded by the temporal region occupied by the first half of the match" xsd:string
domain: BFO:0000003 ! occurrent
range: BFO:0000003 ! occurrent
is_transitive: true
inverse_of: BFO:0000063 ! precedes

[Typedef]
id: BFO:0000063
name: precedes
def: "x precedes y if and only if the time point at which x ends is before or equivalent to the time point at which y starts. Formally: x precedes y iff ω(x) <= α(y), where α is a function that maps a process to a start point, and ω is a function that maps a process to an end point." []
property_value: skos:definition "(Elucidation) precedes is a relation between occurrents o, o' such that if t is the temporal extent of o & t' is the temporal extent of o' then either the last instant of o is before the first instant of o' or the last instant of o is the first instant of o' & neither o nor o' are temporal instants" xsd:string
property_value: skos:example "The temporal region occupied by Mary's birth precedes the temporal region occupied by Mary's death." xsd:string
domain: BFO:0000003 ! occurrent
range: BFO:0000003 ! occurrent
is_transitive: true

[Typedef]
id: BFO:0000066
name: occurs in
property_value: skos:definition "b occurs in c =Def b is a process or a process boundary & c is a material entity or site & there exists a spatiotemporal region r & b occupies spatiotemporal region r & for all time t, if b exists at t then c exists at t & there exist spatial regions s and s' where b spatially projects onto s at t & c occupies spatial region s' at t & s is a continuant part of s' at t" xsd:string
property_value: skos:example "A process of digestion occurs in the interior of an organism; a process of loading artillery rounds into a tank cannon occurs in the interior of the tank" xsd:string
inverse_of: BFO:0000183 ! environs

[Typedef]
id: BFO:0000108
name: exists at
property_value: skos:definition "(Elucidation) exists at is a relation between a particular and some temporal region at which the particular exists" xsd:string
property_value: skos:example "First World War exists at 1914-1916; Mexico exists at January 1, 2000" xsd:string
domain: BFO:0000001 ! entity
range: BFO:0000008 ! temporal region

[Typedef]
id: BFO:0000117
name: has occurrent part
property_value: skos:definition "b has occurrent part c =Def c occurrent part of b" xsd:string
property_value: skos:example "Mary's life has occurrent part Mary's 5th birthday" xsd:string
domain: BFO:0000003 ! occurrent
range: BFO:0000003 ! occurrent
is_transitive: true
is_a: BFO:0000051 ! has part
inverse_of: BFO:0000132 ! occurrent part of

[Typedef]
id: BFO:0000118
name: has proper occurrent part
property_value: skos:definition "b has proper occurrent part c =Def b has occurrent part c & b and c are not identical" xsd:string
property_value: skos:example "As for has occurrent part." xsd:string
domain: BFO:0000003 ! occurrent
range: BFO:0000003 ! occurrent
is_transitive: true
is_a: BFO:0000117 ! has occurrent part
inverse_of: BFO:0000138 ! proper occurrent part of

[Typedef]
id: BFO:0000121
name: has temporal part
property_value: skos:definition "b has temporal part c =Def c temporal part of b" xsd:string
property_value: skos:example "Your life has temporal part the first year of your life" xsd:string
domain: BFO:0000003 ! occurrent
range: BFO:0000003 ! occurrent
is_transitive: true
is_a: BFO:0000117 ! has occurrent part
inverse_of: BFO:0000139 ! temporal part of

[Typedef]
id: BFO:0000132
name: occurrent part of
property_value: skos:definition "(Elucidation) occurrent part of is a relation between occurrents b and c when b is part of c" xsd:string
property_value: skos:example "Mary's 5th birthday is an occurrent part of Mary's life; the first set of the tennis match is an occurrent part of the tennis match" xsd:string
domain: BFO:0000003 ! occurrent
range: BFO:0000003 ! occurrent
is_transitive: true
is_a: BFO:0000050 {comment="\"occurrent part of\" is not a BFO2020 temporalized relation. It just restricts the domain and range to \"occurrent\". That's why is should be OK to make it sub property of RO \"part of\""} ! part of

[Typedef]
id: BFO:0000136
name: proper temporal part of
property_value: skos:definition "b proper temporal part of c =Def b temporal part of c & not (b = c)" xsd:string
property_value: skos:example "As for temporal part of." xsd:string
domain: BFO:0000003 ! occurrent
range: BFO:0000003 ! occurrent
is_a: BFO:0000139 ! temporal part of
inverse_of: BFO:0000181 ! has proper temporal part

[Typedef]
id: BFO:0000138
name: proper occurrent part of
property_value: skos:definition "b proper occurrent part of c =Def b occurrent part of c & b and c are not identical" xsd:string
property_value: skos:example "As for occurrent part of." xsd:string
domain: BFO:0000003 ! occurrent
range: BFO:0000003 ! occurrent
is_transitive: true
is_a: BFO:0000132 ! occurrent part of

[Typedef]
id: BFO:0000139
name: temporal part of
property_value: skos:definition "b temporal part of c =Def b occurrent part of c & (b and c are temporal regions) or (b and c are spatiotemporal regions & b temporally projects onto an occurrent part of the temporal region that c temporally projects onto) or (b and c are processes or process boundaries & b occupies a temporal region that is an occurrent part of the temporal region that c occupies)" xsd:string
property_value: skos:example "Your heart beating from 4pm to 5pm today is a temporal part of the process of your heart beating; the 4th year of your life is a temporal part of your life, as is the process boundary which separates the 3rd and 4th years of your life; the first quarter of a game of football is a temporal part of the whole game" xsd:string
domain: BFO:0000003 ! occurrent
range: BFO:0000003 ! occurrent
is_transitive: true
is_a: BFO:0000132 ! occurrent part of

[Typedef]
id: BFO:0000153
name: temporally projects onto
property_value: skos:definition "(Elucidation) temporally projects onto is a relation between a spatiotemporal region s and some temporal region which is the temporal extent of s" xsd:string
property_value: skos:example "The world line of a particle temporally projects onto the temporal region extending from the beginning to the end of the existence of the particle" xsd:string
domain: BFO:0000011 ! spatiotemporal region
range: BFO:0000008 ! temporal region
is_functional: true

[Typedef]
id: BFO:0000181
name: has proper temporal part
property_value: skos:definition "b has proper temporal part c =Def c proper temporal part of b" xsd:string
property_value: skos:example "As for has temporal part." xsd:string
domain: BFO:0000003 ! occurrent
range: BFO:0000003 ! occurrent
is_a: BFO:0000121 ! has temporal part

[Typedef]
id: BFO:0000183
name: environs
property_value: skos:definition "b environs c =Def c occurs in b" xsd:string
property_value: skos:example "Mouth environs process of mastication; city environs traffic" xsd:string

[Typedef]
id: BFO:0000184
name: history of
property_value: skos:definition "(Elucidation) history of is a relation between history b and material entity c such that b is the unique history of c" xsd:string
property_value: skos:example "This life is the history of this organism" xsd:string
domain: BFO:0000182 ! history
range: BFO:0000040 ! material entity
is_functional: true
is_inverse_functional: true
inverse_of: BFO:0000185 ! has history

[Typedef]
id: BFO:0000185
name: has history
property_value: skos:definition "b has history c =Def c history of b" xsd:string
property_value: skos:example "This organism has history this life" xsd:string
domain: BFO:0000040 ! material entity
range: BFO:0000182 ! history

[Typedef]
id: BFO:0000199
name: occupies temporal region
property_value: skos:definition "p occupies temporal region t =Def p is a process or process boundary & the spatiotemporal region occupied by p temporally projects onto t" xsd:string
property_value: skos:example "The Second World War occupies the temporal region September 1, 1939 - September 2, 1945" xsd:string
range: BFO:0000008 ! temporal region
is_functional: true

[Typedef]
id: BFO:0000200
name: occupies spatiotemporal region
property_value: skos:definition "(Elucidation) occupies spatiotemporal region is a relation between a process or process boundary p and the spatiotemporal region s which is its spatiotemporal extent" xsd:string
property_value: skos:example "A particle emitted by a nuclear reactor occupies the spatiotemporal region which is its trajectory" xsd:string
range: BFO:0000011 ! spatiotemporal region
is_functional: true

[Typedef]
id: BFO:0000221
name: first instant of
property_value: skos:definition "t first instant of t' =Def t is a temporal instant & t' is a temporal region t' & t precedes all temporal parts of t' other than t" xsd:string
property_value: skos:example "An hour starting at midnight yesterday has first instant midnight yesterday" xsd:string
domain: BFO:0000203 ! temporal instant
range: BFO:0000008 ! temporal region
inverse_of: BFO:0000222 ! has first instant

[Typedef]
id: BFO:0000222
name: has first instant
property_value: skos:definition "t has first instant t' =Def t' first instant of t" xsd:string
property_value: skos:example "The first hour of a year has first instant midnight on December 31" xsd:string
domain: BFO:0000008 ! temporal region
range: BFO:0000203 ! temporal instant
is_functional: true

[Typedef]
id: BFO:0000223
name: last instant of
property_value: skos:definition "t last instant of t' =Def t is a temporal instant & t' is a temporal region & all temporal parts of t' other than t precede t" xsd:string
property_value: skos:example "Last midnight is the last instant of yesterday" xsd:string
domain: BFO:0000203 ! temporal instant
range: BFO:0000008 ! temporal region
inverse_of: BFO:0000224 ! has last instant

[Typedef]
id: BFO:0000224
name: has last instant
property_value: skos:definition "t has last instant t' =Def t' last instant of t" xsd:string
property_value: skos:example "The last hour of a year has last instant midnight December 31" xsd:string
domain: BFO:0000008 ! temporal region
range: BFO:0000203 ! temporal instant
is_functional: true

[Typedef]
id: COB:0000081
name: intended to realize

[Typedef]
id: IAO:0000039
name: has measurement unit label
range: IAO:0000003 ! measurement unit label
is_functional: true
